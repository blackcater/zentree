  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "code-inspector-plugin": "^1.4.4",
    "dotenv": "^17.3.1",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
