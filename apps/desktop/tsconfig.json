{
  "extends": "@acme-ai/tsconfig/electron.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["@types/bun", "electron-vite/node"],
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./src/*"],
      "@main/*": ["./src/main/*"],
      "@renderer/*": ["./src/renderer/src/*"],
      "@acme-ai/ui": ["../../packages/ui/src/index.ts"],
      "@acme-ai/ui/*": ["../../packages/ui/src/*/index.ts"]
    }
  },
  "include": [
    "./src/**/*",
    "./src/**/*.tsx",
    "./src/preload/*.d.ts",
    "src/renderer/**/*.d.ts",
    "electron.vite.config.ts"
  ],
  "exclude": ["node_modules", "out"]
}
